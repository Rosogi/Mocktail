# ============================================================
#  MockServer — environment variables
#  Copy this file to .env and fill in your values.
#  .env is read automatically by docker compose.
# ============================================================

# ── Profile ──────────────────────────────────────────────────
# "dev"  = embedded LDAP (test users from ldap/test-users.ldif)
# "prod" = real LDAP server
SPRING_PROFILES_ACTIVE=dev

# ── Database ──────────────────────────────────────────────────
DB_PASS=mockserver

# ── LDAP (only needed when SPRING_PROFILES_ACTIVE=prod) ──────
LDAP_URL=ldap://your-ldap-server:389
LDAP_BASE_DN=dc=company,dc=com
LDAP_USER_DN_PATTERN=uid={0},ou=people
LDAP_GROUP_SEARCH_BASE=ou=groups

# Manager account — only required if anonymous bind is not allowed
LDAP_MANAGER_DN=cn=readonly,dc=company,dc=com
LDAP_MANAGER_PASSWORD=secret
